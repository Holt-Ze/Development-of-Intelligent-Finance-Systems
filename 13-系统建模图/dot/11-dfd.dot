digraph dfd {
  graph [label="财务管理系统数据流图（Level 1）", labelloc=t, fontsize=22, rankdir=LR, splines=ortho, nodesep=0.7, ranksep=1.0];
  node [fontname="Sans", fontsize=11, style="filled", fillcolor="white", color="#475569"];
  edge [fontname="Sans", fontsize=10, color="#475569"];

  admin [shape=box, fillcolor="#fff7ed", label="管理员"];
  finance [shape=box, fillcolor="#dbeafe", label="财务员"];

  p1 [shape=circle, width=1.3, fillcolor="#d1fae5", label="1.0\n登录与权限"];
  p2 [shape=circle, width=1.3, fillcolor="#dcfce7", label="2.0\n基础信息管理"];
  p3 [shape=circle, width=1.3, fillcolor="#dcfce7", label="3.0\n收支管理"];
  p4 [shape=circle, width=1.3, fillcolor="#cffafe", label="4.0\n报表统计"];
  p5 [shape=circle, width=1.3, fillcolor="#fef3c7", label="5.0\n备份与恢复"];

  d1 [shape=cylinder, fillcolor="#f8fafc", label="D1\n用户与角色数据"];
  d2 [shape=cylinder, fillcolor="#f8fafc", label="D2\n部门/账户/类别数据"];
  d3 [shape=cylinder, fillcolor="#f8fafc", label="D3\n收入/支出记录数据"];
  d4 [shape=cylinder, fillcolor="#f8fafc", label="D4\n备份记录与备份文件"];

  admin -> p1 [label="用户名 / 密码"];
  finance -> p1 [label="用户名 / 密码"];
  p1 -> admin [label="token / 角色 / 菜单"];
  p1 -> finance [label="token / 角色 / 菜单"];
  p1 -> d1 [label="读取账号与角色"];

  admin -> p2 [label="主数据维护请求"];
  p2 -> admin [label="维护结果"];
  p2 -> d2 [label="新增 / 修改 / 停用"];

  admin -> p3 [label="收入 / 支出录入"];
  finance -> p3 [label="收入 / 支出录入"];
  p3 -> admin [label="录入结果 / 查询结果"];
  p3 -> finance [label="录入结果 / 查询结果"];
  p3 -> d2 [label="读取有效部门、账户、类别"];
  p3 -> d3 [label="写入 / 查询记录"];

  admin -> p4 [label="统计条件"];
  finance -> p4 [label="统计条件"];
  p4 -> admin [label="汇总结果 / 趋势数据"];
  p4 -> finance [label="汇总结果 / 趋势数据"];
  p4 -> d3 [label="读取有效收支记录"];
  p4 -> d2 [label="读取部门 / 类别名称"];

  admin -> p5 [label="创建 / 恢复备份"];
  p5 -> admin [label="备份文件 / 恢复结果"];
  p5 -> d3 [label="读取当前业务数据"];
  p5 -> d1 [label="读取账号角色数据"];
  p5 -> d2 [label="读取主数据"];
  p5 -> d4 [label="写入备份记录 / 备份文件"];
}
